#include<stdio.h>
int main()
{
    int t;
    scanf("%d",&t);
    while(t--)
    {   
        long long sum=0;
        long long n,a,b;
        scanf("%lld %lld %lld",&n,&a,&b);
        long long group = n/3;
        long long rem=n-group*3;

            if(group==0)
            {
                if(rem*a < b){
                    sum+= rem*a;
                }
                else{
                    sum+= b;
                }
            }
            else if(3*a <= b)
            {
                sum = sum + n*a;
            }
            else if(3*a > b)
            {
              sum+= group*b + rem*a; 
            }
        printf("%lld\n",sum);     
    }
    return 0;
}
